# Copy to .env for local development. On Oxygen, set these per
# environment in admin → Hydrogen → Storefront settings →
# Environments and variables (mark the secret as secret).

# Dev Dashboard app credentials (dev.shopify.com → your app → Settings).
# Admin API tokens are minted at runtime via the OAuth client
# credentials grant — the app must be installed on your store, and the
# app and store must belong to the same Dev Dashboard organization.
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""

# The shop the wall's data comes from — where the app above is
# installed, e.g. your-store.myshopify.com.
ADMIN_SHOP_DOMAIN=""

# Local dev only: Oxygen injects PUBLIC_STORE_DOMAIN automatically once
# the storefront is linked. Usually the same value as ADMIN_SHOP_DOMAIN.
PUBLIC_STORE_DOMAIN=""

# Admin GraphQL API version.
SHOPIFY_ADMIN_API_VERSION="2026-07"

# Currency code shown on the wall (e.g. USD, EUR, CAD).
DISPLAY_CURRENCY="USD"

# Optional shared-secret gate for / and /api/snapshot (?key=<token>).
# Leave empty to keep the wall open.
KIOSK_TOKEN=""

# Any random string — signs session cookies.
SESSION_SECRET="change-me"
